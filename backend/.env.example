# Application
SERVER_NAME=Consolidated MAF Agent
SERVER_VERSION=0.1.0
HOST=0.0.0.0
PORT=9098
LOG_LEVEL=INFO

# CORS (comma-separated origins; * means allow all)
CORS_ALLOW_ORIGINS=*

# HTTPS (disabled by default)
HTTPS_ENABLED=false
SSL_CERTFILE=
SSL_KEYFILE=

# Rate limiting (disabled by default)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_DEFAULT=60/minute

# Azure / Foundry (REQUIRED)
AZURE_AI_PROJECT_ENDPOINT=
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=gpt-4o

# Hosted Foundry agent (used as a tool)
TRAVEL_AGENT_NAME=travel-support-agent
TRAVEL_AGENT_VERSION=2

# MCP servers
MS_LEARN_MCP_URL=https://learn.microsoft.com/api/mcp
MAGIC_V22_MCP_URL=http://localhost:9898/mcp
API_KEY=

# Paths (relative to backend/ unless absolute)
LOGS_DIR=../logs
BLACKLIST_PATH=../db/blacklist.txt

# Chat history database (SQLAlchemy URL). Same default as the notebook.
CHAT_HISTORY_DATABASE_URL=sqlite:///../db/chat_history.db
DATABASE_URL=sqlite:///../db/tickets.db
